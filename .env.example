# Modèle de configuration — copier vers `.env.local` puis renseigner les valeurs.
# `.env.local` est ignoré par git (ne jamais committer de secret ni d'URL interne).
# Ce fichier-ci NE doit contenir AUCUNE valeur réelle : c'est un template.

# === Dolibarr Maître ===
# Mode d'accès à la couche de provisioning :
#   - "mock" (défaut) : simulation locale, aucun appel réseau — permet de
#     développer et tester tout le front sans accès au serveur ;
#   - "live"          : vrais appels à l'API REST du Dolibarr Maître.
# En "live", l'URL et la clé ci-dessous doivent être renseignées (sinon on
# retombe automatiquement en "mock").
DOLIBARR_MODE=mock

# URL de base de l'API REST du Maître (module « API/Web services REST » activé).
DOLIBARR_API_URL=https://votre-dolibarr-maitre.example.com/api/index.php

# Jeton DOLAPIKEY d'un utilisateur habilité (Tiers + Contrats + objets
# Sell Your SaaS). À générer dans Dolibarr : fiche Utilisateur → onglet « Clé API ».
DOLIBARR_API_KEY=

# Domaine racine des instances : URL d'une instance = <sous-domaine>.<INSTANCE_DOMAIN>
INSTANCE_DOMAIN=pichinov.fr

# URL affichée par le bouton « Accéder à mon espace » du tableau de bord de
# provisioning (instance maître pour l'instant ; deviendra l'URL de l'instance).
MASTER_INSTANCE_URL=https://votre-instance.example.com

# === MailJet (e-mails transactionnels : contact + bienvenue) ===
# Clés API MailJet (Compte → API Key Management). Sans elles, l'envoi retombe
# sur une simple journalisation côté serveur (utile en développement).
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=

# Adresse expéditrice des e-mails sortants (doit être validée côté MailJet).
MAIL_FROM=contact@pichinov.com